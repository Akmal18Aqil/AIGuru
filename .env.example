# ===================================
# GOOGLE API KEY (WAJIB)
# ===================================
# Untuk mendapatkan API key:
# 1. Buka https://aistudio.google.com/apikey
# 2. Login dengan akun Google
# 3. Klik "Create API Key"
# 4. Copy dan paste di bawah ini

GOOGLE_API_KEY=your_api_key_here

# ===================================
# INFORMASI LEMBAGA (OPSIONAL)
# ===================================
# Nama lembaga akan ditampilkan di aplikasi

ORGANIZATION_NAME=Nama Sekolah/Lembaga Anda
